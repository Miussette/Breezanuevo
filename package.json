{
  "name": "breeza-ai",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "python -m uvicorn backend.main:app --reload --port 8787",
    "build": "python -m pip install -r backend/requirements.txt && npm run build -w frontend",
    "start": "python -m uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
